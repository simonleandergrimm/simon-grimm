---
import PageLayout from '../layouts/PageLayout.astro';
---

<PageLayout title="Blog — Simon Grimm" description="Blog posts on biosurveillance, policy, and technology.">
  <div class="container">
    <section class="section">
      <h1 class="page-title">Blog</h1>
      <p class="page-description">
        Posts from my <a href="https://simongrimm.substack.com" target="_blank" rel="noopener noreferrer">Substack</a>.
      </p>
    </section>

    <section class="section">
      <div id="blog-posts" class="card-grid">
        <p class="loading">Loading posts…</p>
      </div>
    </section>
  </div>
</PageLayout>

<script>
  async function loadPosts() {
    const container = document.getElementById('blog-posts');
    if (!container) return;

    try {
      const res = await fetch('https://simongrimm.substack.com/api/v1/posts?limit=50');
      if (!res.ok) throw new Error(`Status ${res.status}`);
      const posts = await res.json();

      if (posts.length === 0) {
        container.innerHTML = '<p class="no-posts">No posts found. Check back soon.</p>';
        return;
      }

      container.innerHTML = posts.map((post: any) => {
        const date = new Date(post.post_date).toLocaleDateString('en-US', {
          year: 'numeric', month: 'long', day: 'numeric',
        });
        const imageHtml = post.cover_image
          ? `<div class="blog-card-image"><img src="${post.cover_image}" alt="" loading="lazy" /></div>`
          : '';
        const excerptHtml = post.subtitle
          ? `<p class="blog-card-excerpt">${post.subtitle}</p>`
          : '';
        return `
          <a href="${post.canonical_url}" class="blog-card" target="_blank" rel="noopener noreferrer">
            ${imageHtml}
            <div class="blog-card-body">
              <time class="blog-card-date">${date}</time>
              <h3 class="blog-card-title">${post.title}</h3>
              ${excerptHtml}
            </div>
          </a>
        `;
      }).join('');
    } catch (e) {
      container.innerHTML = `
        <p class="no-posts">
          Could not load posts. Visit <a href="https://simongrimm.substack.com" target="_blank" rel="noopener noreferrer">my Substack</a> directly.
        </p>
      `;
    }
  }

  loadPosts();
</script>

<style>
  .page-title {
    margin-bottom: var(--space-4);
  }

  .page-description {
    font-size: 1.0625rem;
    color: var(--color-text-secondary);
    max-width: 680px;
  }

  .page-description a {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .section:first-of-type {
    padding-bottom: 0;
  }

  .no-posts {
    color: var(--color-text-tertiary);
    font-style: italic;
  }

  .loading {
    color: var(--color-text-tertiary);
  }
</style>
