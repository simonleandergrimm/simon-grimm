---
import PageLayout from '../layouts/PageLayout.astro';
import BlogCard from '../components/BlogCard.astro';
import { substackPosts } from '../utils/substackPosts';
---

<PageLayout title="Blog — Simon Grimm" description="Blog posts on biosurveillance, policy, and technology.">
  <div class="container">
    <section class="section">
      <h1 class="page-title">Blog</h1>
      <p class="page-description">
        Posts from my <a href="https://simongrimm.substack.com" target="_blank" rel="noopener noreferrer">Substack</a>.
      </p>
    </section>

    <section class="section">
      <div class="card-grid">
        {substackPosts.length === 0 ? (
          <p class="no-posts">
            Could not load posts. Visit <a href="https://simongrimm.substack.com" target="_blank" rel="noopener noreferrer">my Substack</a> directly.
          </p>
        ) : (
          substackPosts.map((post) => (
            <BlogCard
              title={post.title}
              url={post.url}
              date={post.date}
              excerpt={post.excerpt}
              image={post.image}
            />
          ))
        )}
      </div>
    </section>
  </div>
</PageLayout>

<style>
  .page-title {
    margin-bottom: var(--space-4);
  }

  .page-description {
    font-size: 1.0625rem;
    color: var(--color-text-secondary);
    max-width: 680px;
  }

  .page-description a {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .section:first-of-type {
    padding-bottom: 0;
  }

  .no-posts {
    color: var(--color-text-tertiary);
    font-style: italic;
  }
</style>
