---
import PageLayout from '../layouts/PageLayout.astro';
import HeroSection from '../components/HeroSection.astro';
import PublicationCard from '../components/PublicationCard.astro';
import { papers } from '../data/papers';
import { policyBriefs } from '../data/policyBriefs';
import { whitePapers } from '../data/whitePapers';
---

<PageLayout title="Simon Grimm">
  <HeroSection />

  <section id="blog" class="section container">
    <h2 class="section-title">Personal Writing</h2>
    <div id="home-blog-posts" class="card-grid">
      <p class="loading">Loading posts…</p>
    </div>
  </section>

  <section id="policy" class="section container">
    <h2 class="section-title">Policy Briefs</h2>
    <div class="card-grid">
      {policyBriefs.map((brief) => (
        <PublicationCard
          title={brief.title}
          description={brief.description}
          url={brief.url}
          image={brief.image}
          authors={brief.authors}
          date={brief.date}
          category="Policy Brief"
        />
      ))}
    </div>
  </section>

  <section id="white-papers" class="section container">
    <h2 class="section-title">White Papers</h2>
    <div class="card-grid">
      {whitePapers.map((wp) => (
        <PublicationCard
          title={wp.title}
          description={wp.description}
          url={wp.url}
          image={wp.image}
          authors={wp.authors}
          date={wp.date}
          category="White Paper"
        />
      ))}
    </div>
  </section>

  <section id="papers" class="section container">
    <h2 class="section-title">Academic Publications</h2>
    <div class="card-grid">
      {papers.map((paper) => (
        <PublicationCard
          title={paper.title}
          description={paper.description}
          url={paper.url}
          image={paper.image}
          authors={paper.authors}
          date={paper.date}
          category="Article"
          venue={paper.venue}
        />
      ))}
    </div>
  </section>
</PageLayout>

<script>
  async function loadPosts() {
    const container = document.getElementById('home-blog-posts');
    if (!container) return;

    try {
      const res = await fetch('/substack-posts.json');
      if (!res.ok) throw new Error(`Status ${res.status}`);
      const posts = await res.json();

      if (posts.length === 0) {
        container.innerHTML = '<p class="no-posts">No posts found. Check back soon.</p>';
        return;
      }

      container.innerHTML = posts.map((post: any) => {
        const date = new Date(post.post_date).toLocaleDateString('en-US', {
          year: 'numeric', month: 'long', day: 'numeric',
        });
        const optimized = post.cover_image
          ? `https://substackcdn.com/image/fetch/w_720,c_limit,f_auto,q_auto:good,fl_progressive:steep/${encodeURIComponent(post.cover_image)}`
          : null;
        const imageHtml = optimized
          ? `<div class="blog-card-image"><img src="${optimized}" alt="" loading="lazy" /></div>`
          : '';
        const excerptHtml = post.subtitle
          ? `<p class="blog-card-excerpt">${post.subtitle}</p>`
          : '';
        return `
          <a href="${post.canonical_url}" class="blog-card" target="_blank" rel="noopener noreferrer">
            ${imageHtml}
            <div class="blog-card-body">
              <time class="blog-card-date">${date}</time>
              <h3 class="blog-card-title">${post.title}</h3>
              ${excerptHtml}
            </div>
          </a>
        `;
      }).join('');
    } catch (e) {
      container.innerHTML = `
        <p class="no-posts">
          Could not load posts. Visit <a href="https://simongrimm.substack.com" target="_blank" rel="noopener noreferrer">my Substack</a> directly.
        </p>
      `;
    }
  }

  loadPosts();
</script>
