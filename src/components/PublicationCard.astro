---
interface Props {
  title: string;
  description: string;
  url: string;
  image?: string;
  authors: string[];
  date: string;
  category: string;
  venue?: string;
}

const { title, description, url, image, authors, date, venue } = Astro.props;

const formattedDate = new Date(date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
});
---

<a href={url} class="publication-card" target="_blank" rel="noopener noreferrer">
  {image && (
    <div class="card-image">
      <img src={image} alt="" loading="lazy" />
    </div>
  )}
  <div class="card-body">
    <div class="card-meta">
      <span class="date-tag">{formattedDate}</span>
    </div>
    <h3 class="card-title">{title}</h3>
    {venue && <p class="card-venue">{venue}</p>}
    <p class="card-description">{description}</p>
    <p class="card-authors">{authors.join(', ')}</p>
  </div>
</a>

<style>
  .publication-card {
    display: flex;
    flex-direction: column;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    text-decoration: none;
    color: inherit;
  }

  .card-image {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background-color: var(--color-bg);
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .card-body {
    padding: var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    flex: 1;
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .date-tag {
    display: inline-block;
    padding: 2px 10px;
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-tag-text);
    background-color: var(--color-tag-bg);
    border-radius: var(--radius-sm);
    line-height: 1.6;
  }

  .card-title {
    font-size: 1.125rem;
    font-weight: 600;
    line-height: 1.4;
    color: var(--color-text);
    margin: 0;
  }

  .card-venue {
    font-size: 0.875rem;
    font-style: italic;
    color: var(--color-text-tertiary);
    margin: 0;
  }

  .card-description {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-authors {
    font-size: 0.8125rem;
    color: var(--color-text-tertiary);
    margin: 0;
    margin-top: auto;
    padding-top: var(--space-2);
  }
</style>
