---
interface Props {
  title: string;
  url: string;
  date: string;
  excerpt?: string;
  image?: string;
}

const { title, url, date, excerpt, image } = Astro.props;

const formattedDate = new Date(date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<a href={url} class="blog-card" target="_blank" rel="noopener noreferrer">
  {image && (
    <div class="blog-card-image">
      <img src={image} alt="" loading="lazy" />
    </div>
  )}
  <div class="blog-card-body">
    <time class="blog-card-date">{formattedDate}</time>
    <h3 class="blog-card-title">{title}</h3>
    {excerpt && <p class="blog-card-excerpt">{excerpt}</p>}
  </div>
</a>
