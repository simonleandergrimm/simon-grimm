---
interface Props {
  title: string;
  url: string;
  date: string;
  excerpt?: string;
  image?: string;
}

const { title, url, date, excerpt, image } = Astro.props;

const formattedDate = new Date(date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<a href={url} class="blog-card" target="_blank" rel="noopener noreferrer">
  {image && (
    <div class="blog-card-image">
      <img src={image} alt="" loading="lazy" />
    </div>
  )}
  <div class="blog-card-body">
    <time class="blog-card-date">{formattedDate}</time>
    <h3 class="blog-card-title">{title}</h3>
    {excerpt && <p class="blog-card-excerpt">{excerpt}</p>}
  </div>
</a>

<style>
  .blog-card {
    display: flex;
    flex-direction: column;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    text-decoration: none;
    color: inherit;
  }

  .blog-card-image {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background-color: var(--color-bg);
  }

  .blog-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .blog-card-body {
    padding: var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .blog-card-date {
    font-size: 0.8125rem;
    color: var(--color-text-tertiary);
  }

  .blog-card-title {
    font-size: 1.125rem;
    font-weight: 600;
    line-height: 1.4;
    color: var(--color-text);
    margin: 0;
  }

  .blog-card-excerpt {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
